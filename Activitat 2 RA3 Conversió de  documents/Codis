<html>
    <head></head>
    <body>
        <input id="text" placeholder="Nou element">
        <button onclick="afegir()">Afegir</button>

        <ul id="llista"></ul>

        <script>

            function afegir()
            {
                var input = document.getElementById("text");
                var llista = document.getElementById("llista");

                var nouElement = document.createElement("li");

                nouElement.innerText = input.value;

                llista.appendChild(nouElement);

                input.value = "";
            }

        </script>
    </body>
