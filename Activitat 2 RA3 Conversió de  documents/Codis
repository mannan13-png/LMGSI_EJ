<html>
    <head>
        <style>
            /* Classes CSS */
            .destacat {
                background-color: yellow;
                font-weight: bold;
            }

            .amagat {
                display: none;
            }

            .vermell {
                color: red;
            }
        </style>
    </head>
    <body>
        <p id="text">Aquest text canviarà amb classList</p>

        <button onclick="toggleDestacat()">Destacat</button>
        <button onclick="toggleVermell()">Vermell</button>
        <button onclick="toggleAmagat()">Mostrar / Amagar</button>

        <script>
            // Aquí el nostre codi
            // En aquesta activitat HAS d'utilitzar classList (add, remove, toggle o contains)

            let text = document.getElementById("text");

            function toggleDestacat()
            {
                text.classList.toggle("destacat");
            }

            function toggleVermell()
            {
                text.classList.toggle("vermell");
            }

            function toggleAmagat()
            {
                text.classList.toggle("amagat");
            }
        </script>
    </body>
</html>

